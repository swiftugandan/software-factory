{
  "name": "tinylink",
  "version": "0.1.0",
  "private": true,
  "description": "TinyLink URL shortener (ADR-0001: Node.js 22 LTS, plain JS ESM, no build step).",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "lint": "eslint .",
    "test": "node --test --test-concurrency=1 \"tests/**/*.test.js\"",
    "coverage": "c8 --check-coverage --lines 70 --branches 70 --functions 70 --reporter=text --reporter=lcov node --test --test-concurrency=1 \"tests/**/*.test.js\"",
    "migrate": "node-pg-migrate",
    "start": "node src/backend/server.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^5.1.0",
    "node-pg-migrate": "^7.9.1",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "c8": "^10.1.2",
    "eslint": "^10.1.0",
    "supertest": "^7.0.0"
  }
}
