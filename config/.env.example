# TinyLink environment variables (ADR-0013). Copy this file to `.env` in the repo root for
# local development; `.env` is gitignored and must never contain real secrets in this file.
# CI and production set these as real environment variables — no `.env` file is used there.

# Runtime
NODE_ENV=development
PORT=3000

# Postgres connection (ADR-0004). Local/CI use the peer-auth Unix socket, so no password is
# needed. The socket directory and OS/DB role (`root` in this environment, Ledger #26) are
# passed explicitly via `?host=` and the URL's user segment rather than relying on ambient
# $PGHOST/$PGUSER/$USER, so the same DSN works the same way in every shell/CI runner:
#   dev:  postgresql://root@/tinylink?host=/var/run/postgresql
#   test: postgresql://root@/tinylink_test?host=/var/run/postgresql
DATABASE_URL=postgresql://root@/tinylink?host=/var/run/postgresql

# Fully-qualified host used to build the short URL returned on create (AC-8, Ledger #15).
SHORT_LINK_BASE_URL=http://localhost:3000

# Short-code collision-retry cap (AC-6, Ledger #12, ADR-0010). Default 10 if unset.
CODE_RETRY_MAX=10

# Redirect p95 server-time latency budget in ms (AC-12). Default 100 if unset.
REDIRECT_P95_BUDGET_MS=100

# Signs/derives server-side session handling (ADR-0009). Required; use a long random value.
# Example (do not reuse): openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-value

# Google OAuth (Ledger #18, ADR-0009). Required only to enable Google sign-in; leave unset to
# run with email/password only (config/auth-providers.js reports the provider as disabled).
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URI=http://localhost:3000/auth/oauth/google/callback
