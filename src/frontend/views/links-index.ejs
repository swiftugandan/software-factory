<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Your links - TinyLink</title>
  <link rel="stylesheet" href="/assets/style.css">
</head>
<body>
  <main class="page page-links-index">
    <h1>Your links</h1>
    <p><a href="/app/links/new" data-testid="create-link-nav">Create a new link</a></p>

    <% if (links.length === 0) { %>
      <p data-testid="links-empty-state">You haven't created any links yet. Create your first one to get started.</p>
    <% } else { %>
      <table data-testid="links-table">
        <thead>
          <tr>
            <th>Code</th>
            <th>Short URL</th>
            <th>Long URL</th>
            <th>Created at</th>
            <th>Clicks</th>
          </tr>
        </thead>
        <tbody>
          <% links.forEach((link) => { %>
            <tr data-testid="link-row" data-code="<%= link.code %>">
              <td data-testid="link-code"><%= link.code %></td>
              <td><a data-testid="link-short-url" href="<%= link.short_url %>"><%= link.short_url %></a></td>
              <td data-testid="link-long-url"><%= link.long_url %></td>
              <td data-testid="link-created-at"><%= link.created_at %></td>
              <td data-testid="link-click-count"><%= link.click_count %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>

    <nav data-testid="pagination" aria-label="Pagination">
      <% if (page > 1) { %>
        <a data-testid="pagination-prev" href="/app/links?page=<%= page - 1 %>">Previous</a>
      <% } %>
      <span data-testid="pagination-current-page">Page <%= page %></span>
      <% if (hasNext) { %>
        <a data-testid="pagination-next" href="/app/links?page=<%= page + 1 %>">Next</a>
      <% } %>
    </nav>
  </main>
</body>
</html>
