<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Create a short link - TinyLink</title>
  <link rel="stylesheet" href="/assets/style.css">
</head>
<body>
  <main class="page page-links-new">
    <p><a href="/app/links" data-testid="back-to-links">Back to your links</a></p>
    <h1>Create a short link</h1>

    <% if (error) { %>
      <p class="error" role="alert" data-testid="create-link-error"><%= error %></p>
    <% } %>

    <% if (result) { %>
      <section data-testid="create-link-result">
        <p>Your short link is ready.</p>
        <dl>
          <dt>Code</dt>
          <dd data-testid="result-code"><%= result.code %></dd>
          <dt>Short URL</dt>
          <dd><a data-testid="result-short-url" href="<%= result.short_url %>"><%= result.short_url %></a></dd>
          <dt>Long URL</dt>
          <dd data-testid="result-long-url"><%= result.long_url %></dd>
          <dt>Created at</dt>
          <dd data-testid="result-created-at"><%= result.created_at %></dd>
        </dl>
      </section>
    <% } %>

    <form method="POST" action="/app/links/new" data-testid="create-link-form">
      <div class="field">
        <label for="longUrl">URL to shorten</label>
        <input id="longUrl" type="text" name="longUrl" value="<%= longUrl %>" placeholder="https://example.com/a-long-page" required>
      </div>
      <button type="submit" data-testid="create-link-submit">Create short link</button>
    </form>
  </main>
</body>
</html>
